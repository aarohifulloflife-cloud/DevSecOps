{
  "name": "my-app",
  "version": "1.0.0",
  "description": "Simple to-do list app for DevSecOps pipeline assessment",
  "scripts": {
    "clean": "rimraf dist",
    "prebuild": "shx mkdir -p dist/css dist/js",
    "copy-html": "shx cp src/index.html dist/",
    "minify-css": "cleancss -o dist/css/style.min.css src/css/style.css",
    "minify-js": "terser src/js/script.js -o dist/js/script.min.js --compress --mangle",
    "build": "npm run clean && npm run prebuild && npm run copy-html && npm run minify-css && npm run minify-js",
    "test": "jest",
    "lint": "eslint src/js/"
  },
  "devDependencies": {
    "clean-css-cli": "^5.6.3",
    "terser": "^5.27.0",
    "jest": "^29.7.0",
    "eslint": "^8.57.0",
    "rimraf": "^5.0.5",
    "shx": "^0.3.4"
  }
}